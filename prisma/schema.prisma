// KaryaDhara — Prisma Schema
// "Flow of Tasks" — API-first task planner

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH (NextAuth.js)
// ─────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  password      String?
  role          Role      @default(MEMBER)
  timezone      String    @default("UTC")
  preferences   Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts        Account[]
  sessions        Session[]

  // App relations
  workspaces      WorkspaceMember[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  tasks           Task[]            @relation("TaskAssignee")
  createdTasks    Task[]            @relation("TaskCreator")
  comments        Comment[]
  activities      Activity[]
  timers          Timer[]
  apiKeys         ApiKey[]
  notifications   Notification[]
    // Wave 3 Relations
  uploadedAttachments Attachment[]    @relation("UserAttachments")
  multiAssignedTasks  TaskAssignee[]  @relation("MultiAssignedTasks")
  timeEntries         TimeEntry[]     @relation("UserTimeEntries")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// WORKSPACE
// ─────────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  ownerId     String
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  projects     Project[]
  labels       Label[]
  webhooks     Webhook[]
  integrations Integration[]
  activities   Activity[]
  apiKeys      ApiKey[]

  @@index([ownerId])
  @@index([slug])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// PROJECT & SECTION
// ─────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?
  color       String        @default("#6366f1")
  icon        String?
  status      ProjectStatus @default(ACTIVE)
  isPublic    Boolean       @default(false)
  position    Float         @default(0)
    progress    Float      @default(0)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sections   Section[]
  tasks      Task[]
  activities Activity[]

  @@index([workspaceId])
  @@index([workspaceId, status])
}

model Section {
  id        String   @id @default(cuid())
  projectId String
  name      String
  position  Float    @default(0)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
}

// ─────────────────────────────────────────────
// TASK
// ─────────────────────────────────────────────

enum TaskPriority {
  P1 // Urgent
  P2 // High
  P3 // Medium
  P4 // Low
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
  ARCHIVED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(P3)
  position    Float        @default(0)

  // Dates
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?

  // Recurrence
  recurrence Json? // { type: 'daily'|'weekly'|'monthly'|'custom', cron: '...' }

  // Relations (IDs)
  projectId  String?
  sectionId  String?
  assigneeId String?
  creatorId  String

  // Subtasks
  parentId String?

  // Metadata
  isArchived Boolean  @default(false)
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  project  Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  section  Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User     @relation("TaskCreator", fields: [creatorId], references: [id])
  parent   Task?    @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]   @relation("SubTasks")

  // Linked
  labels     TaskLabel[]
  comments   Comment[]
  activities Activity[]
  timers     Timer[]

  // Dependencies
  blockedBy     TaskDependency[] @relation("Blocking")
  blocks        TaskDependency[] @relation("Blocked")
  notifications Notification[]

  // Wave 3 Relations
  checklist       ChecklistItem[]   @relation("TaskChecklist")
  attachments     Attachment[]      @relation("TaskAttachments")
  multiAssignees  TaskAssignee[]    @relation("MultiAssignees")
  timeEntries     TimeEntry[]       @relation("TaskTimeEntries")

  @@index([projectId])
  @@index([sectionId])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([parentId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([assigneeId, dueDate])
}

model TaskDependency {
  id         String   @id @default(cuid())
  blockingId String // this task blocks...
  blockedId  String // ...this task
  createdAt  DateTime @default(now())

  blocking Task @relation("Blocking", fields: [blockingId], references: [id], onDelete: Cascade)
  blocked  Task @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockingId, blockedId])
  @@index([blockingId])
  @@index([blockedId])
}

// ─────────────────────────────────────────────
// LABEL
// ─────────────────────────────────────────────

model Label {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#94a3b8")
  createdAt   DateTime @default(now())

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model TaskLabel {
  taskId    String
  labelId   String
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([taskId])
  @@index([labelId])
}

// ─────────────────────────────────────────────
// COMMENT
// ─────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String   @db.Text
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

// ─────────────────────────────────────────────
// ACTIVITY
// ─────────────────────────────────────────────

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  TASK_ASSIGNED
  TASK_UNASSIGNED
  COMMENT_ADDED
  COMMENT_EDITED
  COMMENT_DELETED
  LABEL_ADDED
  LABEL_REMOVED
  STATUS_CHANGED
  PRIORITY_CHANGED
  DUE_DATE_CHANGED
  SECTION_CHANGED
  PROJECT_CREATED
  PROJECT_UPDATED
  MEMBER_ADDED
  MEMBER_REMOVED
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  userId      String
  workspaceId String?
  projectId   String?
  taskId      String?
  meta        Json         @default("{}") // { from, to, field, ... }
  createdAt   DateTime     @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// TIMER (Pomodoro)
// ─────────────────────────────────────────────

enum TimerType {
  POMODORO
  STOPWATCH
  CUSTOM
}

enum TimerStatus {
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

model Timer {
  id        String      @id @default(cuid())
  taskId    String
  userId    String
  type      TimerType   @default(POMODORO)
  status    TimerStatus @default(RUNNING)
  duration  Int         @default(1500) // seconds (25 min Pomodoro default)
  elapsed   Int         @default(0) // seconds elapsed
  startedAt DateTime    @default(now())
  endedAt   DateTime?
  createdAt DateTime    @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([userId, status])
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

enum NotificationType {
  DUE_REMINDER
  OVERDUE_ALERT
  TASK_ASSIGNED
  TASK_COMPLETED
  COMMENT_ADDED
  STATUS_CHANGED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  taskId    String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// API KEY
// ─────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  name        String
  keyHash     String    @unique // bcrypt hash of the actual key
  prefix      String // e.g. "kd_" + first 6 chars for display
  scopes      String[]  @default(["read"])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([keyHash])
}

// ─────────────────────────────────────────────
// WEBHOOK
// ─────────────────────────────────────────────

enum WebhookEvent {
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_DELETED
  COMMENT_ADDED
  PROJECT_CREATED
  MEMBER_ADDED
  MEMBER_REMOVED
}

model Webhook {
  id           String         @id @default(cuid())
  workspaceId  String
  name         String
  url          String
  secret       String? // HMAC signing secret
  events       WebhookEvent[]
  isActive     Boolean        @default(true)
  failCount    Int            @default(0)
  lastCalledAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([workspaceId])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?  @db.Text
  duration   Int? // ms
  success    Boolean  @default(false)
  attempts   Int      @default(1)
  createdAt  DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([webhookId, success])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// INTEGRATION
// ─────────────────────────────────────────────

enum IntegrationType {
  GOOGLE_CALENDAR
  SLACK
  GITHUB
  ZAPIER
  MAKE
  EMAIL
  NOTION
  CUSTOM
}

model Integration {
  id          String          @id @default(cuid())
  workspaceId String
  type        IntegrationType
  name        String
  config      Json            @default("{}") // provider-specific config
  credentials Json            @default("{}") // encrypted tokens
  isActive    Boolean         @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type])
  @@index([workspaceId])
}


// ————————————————————————————————————
// WAVE 3: Checklists, Attachments, Multi-Assign, Time Tracking
// ————————————————————————————————————

model ChecklistItem {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  position  Int      @default(0)
  taskId    String
  createdAt DateTime @default(now())

  task      Task     @relation("TaskChecklist", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Attachment {
  id           String   @id @default(cuid())
  name         String
  url          String
  size         Int
  mimeType     String
  taskId       String
  uploadedById String
  createdAt    DateTime @default(now())

  task         Task     @relation("TaskAttachments", fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("UserAttachments", fields: [uploadedById], references: [id])

  @@index([taskId])
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task      Task     @relation("MultiAssignees", fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("MultiAssignedTasks", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String
  userId      String
  startTime   DateTime
  endTime     DateTime?
  duration    Int?      // in seconds
  description String?
  createdAt   DateTime  @default(now())

  task        Task      @relation("TaskTimeEntries", fields: [taskId], references: [id], onDelete: Cascade)
  user        User      @relation("UserTimeEntries", fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}